select mb.MEMBER_ID, mb.MEMBER_NAME, mb.MEMBER_STATUS_CODE
     , mb.FORMALIZED_DATETIME
  from MEMBER mb
 where mb.MEMBER_STATUS_CODE = 'PRV'
   and mb.FORMALIZED_DATETIME is not null
